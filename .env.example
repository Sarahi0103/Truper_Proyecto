# ==================================
# TRUPER PLATFORM - ENVIRONMENT CONFIG
# ==================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file to git!

# ===== DATABASE =====
DB_HOST=postgres
DB_PORT=5432
DB_NAME=trupper_db
DB_USER=truper_admin
DB_PASSWORD=Truper123!Secure  # CHANGE THIS!

# ===== SECURITY =====
ENCRYPTION_KEY=your-256-bit-hex-key-here  # Generate: php -r "echo bin2hex(random_bytes(32));"
ADMIN_IP_WHITELIST=192.168.1.0,10.0.0.5   # Comma-separated list (optional)
ENFORCE_ADMIN_IP_WHITELIST=false           # Set to true to enforce IP whitelist

# ===== EMAIL & NOTIFICATIONS =====
COMPANY_WHATSAPP_PHONE=3317915887
MAILER_HOST=smtp.gmail.com
MAILER_PORT=587
MAILER_USER=your-email@gmail.com
MAILER_PASSWORD=your-app-password         # Use app-specific passwords for Gmail
MAILER_FROM=noreply@truper.com

# ===== APPLICATION =====
APP_ENV=production                         # dev or production
APP_DEBUG=false                            # Always false in production
APP_URL=https://truper-web.onrender.com
SESSION_LIFETIME=3600                      # 1 hour in seconds
SESSION_SECURE=true                        # true for HTTPS only

# ===== LOGGING =====
LOG_LEVEL=info                             # debug, info, warning, error
LOG_PATH=/app/logs

# ===== RENDER.COM DEPLOYMENT =====
# (These are set automatically by Render if using render.yaml)
DATABASE_URL=postgres://user:pass@host:5432/db
